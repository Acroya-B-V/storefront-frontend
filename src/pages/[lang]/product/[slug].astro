---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import SEOHead from '@/components/astro/SEOHead.astro';
import StructuredData from '@/components/astro/StructuredData.astro';
import { formatPrice, langToLocale } from '@/lib/currency';
import { getEffectivePrice, getOriginalPrice, hasUnitDiscount, type PricedItem } from '@/lib/pricing';
import PromoBadge from '@/components/astro/PromoBadge.astro';
import { t } from '@/i18n';
import { fetchAllProducts } from '@/lib/fetch-all';

const { merchant, lang, sdk } = Astro.locals;
const { slug } = Astro.params;
const baseUrl = import.meta.env.API_BASE_URL;
const locale = langToLocale(lang);

// Resolve slug to product — fetch all products and find by slug
// Once the API supports GET /products/?slug=X, this can be simplified
const allProducts = await fetchAllProducts(sdk, {
  vendorId: merchant.merchantId,
  language: lang,
  baseUrl,
});
const product = allProducts.find((p) => (p as Record<string, unknown>).slug === slug) as Record<string, unknown> | undefined;

if (!product) {
  return Astro.redirect(`/${lang}/`);
}

// Fetch full product detail with modifiers using the resolved ID
const { data: detail } = await sdk.GET(`/api/v1/products/{id}/`, {
  params: { path: { id: String(product.id) } },
});

const productData = (detail ?? product) as Record<string, unknown>;
const pricedItem: PricedItem = {
  price: String(productData.price ?? '0'),
  discount: (productData.discount as PricedItem['discount']) ?? null,
};
const effectivePrice = getEffectivePrice(pricedItem);
const originalPrice = getOriginalPrice(pricedItem);
const showStrikethrough = hasUnitDiscount(pricedItem);

const breadcrumbs = [
  { name: merchant.name, url: `/${lang}/` },
  { name: String(productData.name), url: `/${lang}/product/${slug}` },
];
---

<BaseLayout title={String(productData.name)} description={String(productData.description ?? '')}>
  <SEOHead
    slot="head"
    page="product"
    merchant={merchant}
    lang={lang}
    title={String(productData.name)}
    description={String(productData.description ?? '')}
    canonicalUrl={`${Astro.url.origin}/${lang}/product/${slug}`}
    image={productData.image as string | undefined}
  />
  <StructuredData
    slot="head"
    type="product"
    merchant={merchant}
    product={{
      name: String(productData.name),
      price: String(productData.price),
      description: productData.description as string | undefined,
      image: productData.image as string | null,
      slug: slug,
    }}
  />
  <StructuredData slot="head" type="breadcrumb" merchant={merchant} breadcrumbs={breadcrumbs} />

  <Header merchant={merchant} lang={lang} />

  <main class="mx-auto max-w-screen-xl px-4 py-6">
    <div class="grid gap-6 md:grid-cols-2">
      {/* Product image */}
      <div class="aspect-square overflow-hidden rounded-lg bg-card-image">
        {productData.image ? (
          <img
            src={productData.image as string}
            alt={String(productData.name)}
            class="h-full w-full object-cover"
            width="600"
            height="600"
            loading="eager"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-muted-foreground/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
        )}
      </div>

      {/* Product details */}
      <div>
        <div class="flex items-start justify-between gap-3">
          <h1 class="font-heading text-2xl font-bold text-foreground">
            {productData.name}
          </h1>
          {productData.discount && (
            <PromoBadge item={pricedItem} currency={merchant.currency} locale={locale} />
          )}
        </div>

        {productData.description && (
          <p class="mt-2 text-muted-foreground">{productData.description}</p>
        )}

        <div class="mt-4 flex items-baseline gap-2">
          <span class="text-xl font-bold text-foreground">
            {formatPrice(String(effectivePrice), merchant.currency, locale)}
          </span>
          {showStrikethrough && (
            <span class="text-base text-muted-foreground line-through">
              {formatPrice(String(originalPrice), merchant.currency, locale)}
            </span>
          )}
        </div>

        {/* Modifier groups and add-to-cart will be handled by ProductDetail island in Phase 11 */}
        <div class="mt-6">
          <button
            type="button"
            class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-primary px-6 text-base font-semibold text-primary-foreground transition-colors hover:bg-primary/90 disabled:pointer-events-none disabled:opacity-50"
            data-add-to-cart={String(productData.id)}
            disabled={Boolean(productData.sold_out)}
            aria-disabled={productData.sold_out ? 'true' : undefined}
          >
            {productData.sold_out ? t('soldOut', lang) : t('addToOrder', lang)}
          </button>
        </div>

        <a href={`/${lang}/`} class="mt-4 inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          {t('backToMenu', lang)}
        </a>
      </div>
    </div>
  </main>

  <Footer merchant={merchant} lang={lang} />
</BaseLayout>
