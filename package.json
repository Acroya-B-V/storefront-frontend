{
  "name": "@sous/storefront",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "size-limit": [
    {
      "name": "Total client JS (all chunks)",
      "path": "dist/client/**/*.js",
      "limit": "65 KB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@astrojs/preact": "^4.1.3",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.4",
    "@nanostores/preact": "^1.0.0",
    "astro": "^5.18.0",
    "astro-seo": "^1.1.0",
    "lucide-preact": "^0.576.0",
    "nanostores": "^1.1.1",
    "posthog-js": "^1.357.0",
    "preact": "^10.28.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.0",
    "@testing-library/preact": "^3.2.4",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "size-limit": "^12.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
